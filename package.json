{
  "name": "copy-code-path-ref",
  "displayName": "Copy Code Path Reference",
  "description": "Copy AI-friendly file references from selections or multiple cursors, for example /path/to/file.ts#L137-181.",
  "version": "0.1.1",
  "publisher": "ohEVE",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/eveoh354/copy-code-ref.git"
  },
  "bugs": {
    "url": "https://github.com/eveoh354/copy-code-ref/issues"
  },
  "homepage": "https://github.com/eveoh354/copy-code-ref#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copy",
    "code",
    "reference",
    "path",
    "line",
    "line number",
    "ai",
    "codex",
    "claude",
    "claude code",
    "cursor",
    "trae"
  ],
  "activationEvents": [
    "onCommand:copy-code-path-ref.copyReference",
    "onCommand:copy-code-path-ref.openAiCodingToolWithReference",
    "onCommand:copy-code-path-ref.sendReferenceToActiveTerminal",
    "onCommand:copy-code-path-ref.selectAiCodingTool"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copy-code-path-ref.copyReference",
        "title": "Copy Code Path Reference",
        "category": "Copy Code"
      },
      {
        "command": "copy-code-path-ref.openAiCodingToolWithReference",
        "title": "Open AI Coding Tool with Code Path Reference",
        "category": "Copy Code"
      },
      {
        "command": "copy-code-path-ref.sendReferenceToActiveTerminal",
        "title": "Send Code Path Reference to Active Terminal",
        "category": "Copy Code"
      },
      {
        "command": "copy-code-path-ref.selectAiCodingTool",
        "title": "Select AI Coding Tool",
        "category": "Copy Code"
      }
    ],
    "keybindings": [
      {
        "command": "copy-code-path-ref.copyReference",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus"
      },
      {
        "command": "copy-code-path-ref.openAiCodingToolWithReference",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "editorTextFocus"
      },
      {
        "command": "copy-code-path-ref.sendReferenceToActiveTerminal",
        "key": "ctrl+alt+z",
        "mac": "cmd+alt+z",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "copy-code-path-ref.copyReference",
          "group": "navigation@20",
          "when": "editorTextFocus"
        },
        {
          "command": "copy-code-path-ref.openAiCodingToolWithReference",
          "group": "navigation@21",
          "when": "editorTextFocus"
        },
        {
          "command": "copy-code-path-ref.sendReferenceToActiveTerminal",
          "group": "navigation@22",
          "when": "editorTextFocus"
        },
        {
          "command": "copy-code-path-ref.selectAiCodingTool",
          "group": "navigation@30",
          "when": "editorTextFocus"
        }
      ]
    },
    "configuration": {
      "title": "Copy Code Path Reference",
      "properties": {
        "copyCodePathRef.aiCodingTool": {
          "type": "string",
          "default": "codex",
          "enum": [
            "codex",
            "claudeCode"
          ],
          "enumItemLabels": [
            "Codex",
            "Claude Code"
          ],
          "description": "AI coding tool opened by Copy Code: Open AI Coding Tool with Code Path Reference."
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package",
    "lint": "node --check extension.js",
    "prepublish": "npm run lint && vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
